{
//======================== Style ========================

    "layer": "top",
    "position": "top",
    "spacing": 1,
    "height": 36,
    "reload_style_on_change": true,
    "exclusive": true,

//======================== Modules ========================
    "modules-left": [
        "custom/launcher",
        "niri/workspaces",
        "wlr/taskbar",
        "cpu",
        "memory",
        // "custom/cpu-memory",
        "temperature",
        "network",
		"custom/swayidle-toggle",
		"mpris"
    ],
    "modules-center": [
        "clock",
        "custom/notification"
    ],
    "modules-right": [
        "privacy",
        // "idle_inhibitor",
        // "group/misc",
        "custom/clipboard",
        // "custom/vkeyboard",
        "wireplumber",
        "backlight",
        "battery",
        "tray",
        "custom/power"
    ],


//======================== Left ========================
    "custom/launcher": {
        "format": "",
        "on-click": "pkill rofi || rofi -show drun",
        "tooltip-format": "Launcher"
    },

    "niri/workspaces": {
        "format": "{icon}"
    },
    
    "cpu": {
        "interval": 10,
        "format": "{:.1f}%",
        "on-click": "missioncenter"
    },

    "memory": {
		  "states": {
		      "c": 90, // critical
		      "h": 60, // high
		      "m": 30, // medium
		  },
		  "interval": 10,
		  "format": "{used:0.1f}GB",
		  "rotate": 0,
		  "format-m": "󰾅 {used:0.1f}GB",
		  "format-h": "󰓅 {used:0.1f}GB",
		  "format-c": " {used:0.1f}GB",
		  "format-alt": "󰾆 {percentage:0.1f}%",
		  "max-length": 10,
		  "tooltip": true,
		  "tooltip-format": "󰾆  {percentage}%\n  {used:0.1f}GB/{total:0.1f}GB"
	  },
	  
    "custom/cpu-memory": {
		    "exec": "bash -c 'cpu=$(top -bn1 | grep \"Cpu(s)\" | sed \"s/.*, *\\([0-9.]*\\)%* id.*/\\1/\" | awk \"{printf \\\"%.0f\\\", 100 - $1}\"); mem=$(free -m | awk \"/Mem:/ {used=\\$3/1024; printf \\\"%.1f %.0f\\\", used, used*100/\\$2}\"); echo \"$cpu $mem\"'",
		    "interval": 10,
		    "format": " {}/󰾆 {}GB",
		    "format-m": " {}/󰾅 {}GB",
		    "format-h": " {}/󰓅 {}GB",
		    "format-c": " {}/ {}GB",
		    "states": {
		        "c": [90, 100],  // 内存使用率90%以上为critical
		        "h": [60, 89],   // 60-89%为high
		        "m": [30, 59]    // 30-59%为medium
		    },
		    "on-click": "missioncenter",
		    "tooltip": true,
		    "tooltip-format": "CPU: {}%\nMemory: {}GB used"
	},
    
	"temperature": {
		"thermal-zone": 10,
		"critical-threshold": 85,
		"format-critical": "󱗗{temperatureC}°C",
		"format": "{icon}{temperatureC}°C",
		"format-icons": [
		  "",
		  "",
		  "🔥"
		],
		"interval": 5,
		"tooltip": true, 
		"tooltip-format": "CPU温度：{temperatureC}°C"
	  },
    
    "network": {
		"format": "⬇{bandwidthDownBits} ⬆{bandwidthUpBits}",
		"format-disconnected": " 断开",
		"tooltip-format": "下载: {bandwidthDownBytes}\n上传: {bandwidthUpBytes}",
		"interval": 1
	},
    
    "custom/swayidle-toggle": {
		"exec": "bash -c 'if [[ -f /tmp/swayidle-disabled ]]; then echo -e \"☕\\n保持唤醒：屏幕常亮，不锁屏\"; else echo -e \"💤\\n允许休眠：5分钟后自动锁屏\"; fi'",
		"on-click": "bash -c 'if [[ -f /tmp/swayidle-disabled ]]; then rm -f /tmp/swayidle-disabled; systemctl --user start swayidle.service; notify-send \"💤 已恢复锁屏\" \"5分钟后自动息屏\"; echo -e \"💤\\n允许休眠：5分钟后自动锁屏\"; else touch /tmp/swayidle-disabled; systemctl --user stop swayidle.service; notify-send \"☕ 已禁用锁屏\" \"屏幕保持常亮\"; echo -e \"☕\\n保持唤醒：屏幕常亮，不锁屏\"; fi'",
		"interval": 60,
		"tooltip": true
	},
	
	"mpris": {
        "player-icons": {
            "default": "🎵"
        },
        "format": "⏸{dynamic}",
        "format-paused": "▶{dynamic}",
        "format-stopped": "⏹Stopped",
        "interval": 1,
        "max-length": 70
    },


//======================== Middle ========================
   "clock": {
		"format": "{:%d %m月 %H:%M}",
		// "format": "  {:%H:%M   %e %b}",
		"tooltip-format": "<tt>{calendar}</tt>",
		"calendar": {
		    "mode": "month",
		    "on-scroll": 1,
		    "on-click-right": "mode",
		    "on-click": "gnome-calendar",
		    "format": {
		        "months": "<span color='#ffead3'><b>{}</b></span>",
		        "days": "<span color='#ecc6d9'><b>{}</b></span>",
		        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
		        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
		    }
		},
		"interval": 60
	},

    "custom/notification": {
        "tooltip": false,
        "format": "{icon}",
        "format-icons": {
            "notification": "󱅫",
            "none": "󰂚",
            "dnd-notification": "󱏧<span foreground='#1e1e2e'><sup></sup></span>",
            "dnd-none": "󱏧",
            "inhibited-notification": "󰂚<span foreground='#1e1e2e'><sup></sup></span>",
            "inhibited-none": "󰂚",
            "dnd-inhibited-notification": "<span foreground='#1e1e2e'><sup></sup></span>",
            "dnd-inhibited-none": "󱏧"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },


//======================== Right ========================
    "tray": {
        "spacing": 4,
        "icon-size": 25
    },
    
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "☕",   // 咖啡图标表示"保持唤醒"
            "deactivated": "💤"  // 睡眠图标表示"允许休眠"
        },
    },

    "backlight": {
        // "device": "amdgpu_bl2",
        "format": "{icon}{percent}%",
        "format-icons": ["☀"],
        "tooltip": true, 
        "tooltip-format": "屏幕亮度：{percent}%"
    },

    "battery1": {
        "states": {
            "good": 80,
            "warning": 40,
            "critical": 20
        },
        "format-charging": "<b>↯ {capacity}%</b>",
        "format": "{icon} {capacity}%",
        "format-icons": [
            "",
            "",
            "",
            "",
            ""
        ],
        "interval": 30,
        "tooltip": true
    },

	"battery": {
		"bat": "BAT0",
		"states": {
            "good": 80,
            "warning": 40,
            "critical": 20
        },
		"format": "{icon}{capacity}%",
		"format-full": "{capacity}%",
		"format-charging": "{capacity}%",
		"format-plugged": "{capacity}%",
		"format-icons": ["", "", "", "", ""],
		"interval": 30,
        "tooltip": true
	},

    "wireplumber": {
        "format": "{icon}{volume}%",
        //"format-bluetooth": "󰂰",
        //"nospacing": 1,
        "format-muted": "󰝟",
        "format-icons": {
            //"headphone": "",
            "default": [
                "󰖀",
                "󰕾",
                ""
            ]
            // default": ["", "", ""]
        },
        "on-click": "pavucontrol",
        "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "scroll-step": 1
    },
    
    "custom/clipboard": {
        "format": "󰅇",
        "on-click": "pkill fuzzel || /home/pullautumn/.local/share/bin/cliphist-fuzzel-img",
        "tooltip-format": "Clipboard"
    },
    
    "custom/vkeyboard": {
        "format": "󰌌",
        "on-click": "pkill wf-osk || wf-osk --height 200 -a bottom",
        "tooltip-format": "Virtual Keyboard"
    },
    
    "custom/power": {
        "format": "⏻",
        "tooltip": false,
        "on-click": "wlogout -c 15 -b 6 -m 400"
    },
    
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 22,
        "icon-theme": "Numix-Circle",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    
    "privacy": {
        "icon-spacing": 10,
        "icon-size": 16,
        "transition-duration": 250,
        "modules": [
            {
                "type": "screenshare",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-out",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-in",
                "tooltip": true,
                "tooltip-icon-size": 24
            }
        ],
        "ignore-monitor": true,
        "ignore": [
            {
                "type": "audio-in",
                "name": "cava"
            },
            {
                "type": "screenshare",
                "name": "obs"
            }
        ]
    },
    
    "group/misc": {
        "orientation": "horizontal",
        "modules": [
            "custom/clipboard",
            "custom/vkeyboard",
            "custom/screenrecording"
        ]
    }
}
